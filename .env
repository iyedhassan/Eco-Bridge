# EcoBridge backend demo database (SQLite local)
DATABASE_URL="file:./dev.db"

# Local JWT/session secrets. Change in production.
JWT_SECRET="change-this-secret"
AUTH_SECRET="change-this-secret"

# Optional Gemini key. Leave empty to use the rule-based fallback AI.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
